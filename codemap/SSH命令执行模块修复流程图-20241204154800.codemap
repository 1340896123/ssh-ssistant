      "traceTextDiagram": "┌─────────────────────────────────────────────────────────────┐\n│                  修复方案实施流程                               │\n├─────────────────────────────────────────────────────────────┤\n│                                                             │\n│  Phase 1: 数据结构重构                                       │\n│                                                             │\n│  1. 定义CommandExecutor结构体                                │\n│     ├─ session: Arc<Session>                                │\n│     ├─ command_id: String                                   │\n│     └─ cancel_flag: Arc<AtomicBool>                         │\n│                                                             │\n│  2. 修改AppState.command_cancellations                      │\n│     └─ HashMap<CommandID, Arc<AtomicBool>>                  │\n│                                                             │\n│  Phase 2: 核心逻辑重构                                       │\n│                                                             │\n│  3. 重构exec_command函数                                     │\n│     ├─ 使用Arc<Session>替代锁定                              │\n│     ├─ 生成唯一command_id                                   │\n│     └─ 实现RAII自动清理                                      │\n│                                                             │\n│  4. 修改cancel_command_execution                            │\n│     └─ 接收command_id参数                                   │\n│                                                             │\n│  Phase 3: 前端适配                                           │\n│                                                             │\n│  5. 更新AIAssistant.vue                                     │\n│     ├─ 传递tool_call_id作为command_id                        │\n│     └─ 更新取消逻辑                                          │\n│                                                             │\n│  Phase 4: 测试验证                                           │\n│                                                             │\n│  6. 并发测试                                                │\n│  7. 取消功能测试                                            │\n│  8. 错误恢复测试                                            │\n│                                                             │\n└─────────────────────────────────────────────────────────────┘",
