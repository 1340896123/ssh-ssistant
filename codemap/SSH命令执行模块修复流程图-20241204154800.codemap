{
  "schemaVersion": "1.0",
  "id": "ssh-command-execution-fix-flow",
  "metadata": {
    "created": "2024-12-04T15:48:00Z",
    "version": "1.0.0",
    "description": "SSH命令执行模块 deadlock风险和取消机制问题的修复流程图",
    "project": "ssh-ssistant-tauri",
    "severity": "High",
    "components": ["ssh.rs", "AIAssistant.vue", "AppState"]
  },
  "title": "SSH命令执行模块修复流程图",
  "traces": [
    {
      "id": "trace-1",
      "title": "当前问题分析 - Session级Deadlock风险",
      "description": "分析exec_command函数中mutex锁导致的deadlock风险",
      "locations": [
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1854,
          "lineContent": "pub async fn exec_command(",
          "title": "问题入口点",
          "description": "exec_command函数是命令执行的入口，存在潜在的锁持有问题"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1878,
          "lineContent": "let bg_session = client.ssh_pool.get_background_session()",
          "title": "获取后台会话",
          "description": "获取后台会话用于执行命令"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1882,
          "lineContent": "let sess = bg_session.lock().map_err(|e| e.to_string())?;",
          "title": "关键问题点",
          "description": "在整个命令执行期间持有background_session mutex锁，阻塞其他文件操作"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1884,
          "lineContent": "let mut channel = block_on(|| sess.channel_session()).map_err(|e| e.to_string())?;",
          "title": "创建命令通道",
          "description": "在持有锁的情况下创建SSH通道"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1888,
          "lineContent": "loop {",
          "title": "阻塞循环",
          "description": "在整个命令输出读取循环中持续持有mutex锁"
        }
      ],
      "traceTextDiagram": "┌─────────────────────────────────────────────────────────────┐\n│                  Session级Deadlock风险分析                      │\n├─────────────────────────────────────────────────────────────┤\n│                                                             │\n│  exec_command() 开始                                         │\n│       │                                                    │\n│       ▼                                                    │\n│  获取background_session [获取会话]                           │\n│       │                                                    │\n│       ▼                                                    │\n│  🔒 锁定 mutex.lock() [⚠️ 问题点]                           │\n│       │                                                    │\n│       ▼                                                    │\n│  创建SSH通道 channel_session()                              │\n│       │                                                    │\n│       ▼                                                    │\n│  执行命令 channel.exec(command)                             │\n│       │                                                    │\n│       ▼                                                    │\n│  🔄 读取输出循环 (长时间持有锁)                              │\n│  │  ┌─ 检查取消标志                                          │\n│  │  └─ 读取channel数据                                      │\n│       │                                                    │\n│       ▼                                                    │\n│  ❌ 阻塞其他文件操作 (SFTP、上传下载等)                       │\n│       │                                                    │\n│       ▼                                                    │\n│  释放锁 [命令完成或错误时]                                   │\n│                                                             │\n└─────────────────────────────────────────────────────────────┘",
      "traceGuide": {
        "motivation": "解决exec_command函数长时间持有background_session mutex锁导致的deadlock风险，该问题会阻塞所有文件操作（SFTP、上传下载等），严重影响系统并发性能。",
        "details": "当前实现在命令执行的整个生命周期中持有mutex锁，包括：\n1. SSH通道创建\n2. 命令执行\n3. 输出读取循环\n\n这导致：\n- 文件操作无法获取后台会话\n- SFTP操作被阻塞\n- 上传下载功能不可用\n- 用户体验严重受损\n\n关键技术：\n- 使用Arc<Session>替代Arc<Mutex<Session>>\n- 引用计数管理会话生命周期\n- 异步任务分离锁管理"
      }
    },
    {
      "id": "trace-2",
      "title": "命令取消机制逻辑缺陷",
      "description": "分析使用Session ID而非Command ID作为取消键的问题",
      "locations": [
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 168,
          "lineContent": "pub command_cancellations: Mutex<HashMap<String, Arc<AtomicBool>>>, // Session ID -> CancelFlag",
          "title": "问题数据结构",
          "description": "使用Session ID作为key，无法精确控制单个命令的取消"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1874,
          "lineContent": "cancellations.insert(id.clone(), cancel_flag.clone());",
          "title": "错误键值使用",
          "description": "使用session id而非command id插入取消标志"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1839,
          "lineContent": "pub async fn cancel_command_execution(",
          "title": "取消函数实现",
          "description": "取消函数只能按session取消，无法精确到具体命令"
        },
        {
          "path": "src-tauri/src/ssh.rs",
          "lineNumber": 1890,
          "lineContent": "if cancel_flag.load(Ordering::Relaxed) {",
          "title": "取消检查点",
          "description": "在执行循环中检查取消标志"
        }
      ],
      "traceTextDiagram": "┌─────────────────────────────────────────────────────────────┐\n│                命令取消机制逻辑缺陷分析                          │\n├─────────────────────────────────────────────────────────────┤\n│                                                             │\n│  当前实现：                                                  │\n│                                                             │\n│  AppState.command_cancellations                              │\n│  HashMap<SessionID, CancelFlag>  [⚠️ 错误键设计]              │\n│                                                             │\n│  执行流程：                                                  │\n│                                                             │\n│  exec_command(session_id, command)                           │\n│       │                                                    │\n│       ▼                                                    │\n│  创建 cancel_flag                                            │\n│       │                                                    │\n│       ▼                                                    │\n│  🔑 insert(session_id, cancel_flag) [使用session id]         │\n│       │                                                    │\n│       ▼                                                    │\n│  执行命令...                                                 │\n│       │                                                    │\n│       ▼                                                    │\n│  🚫 问题：同一session的多个命令互相干扰                         │\n│  ┌─ 无法精确取消单个命令                                      │\n│  └─ 新命令会覆盖旧命令的取消标志                              │\n│                                                             │\n│  正确设计：                                                  │\n│                                                             │\n│  HashMap<CommandID, CancelFlag>                             │\n│       │                                                    │\n│       ▼                                                    │\n│  🔑 insert(command_id, cancel_flag) [使用command id]         │\n│       │                                                    │\n│       ▼                                                    │\n│  ✅ 精确控制每个命令的取消                                    │\n│                                                             │\n└─────────────────────────────────────────────────────────────┘",
      "traceGuide": {
        "motivation": "修复命令取消机制中使用Session ID而非Command ID的逻辑缺陷，实现精确的命令级取消控制。",
        "details": "当前问题：\n1. 使用Session ID作为取消键，同一会话的多个命令会互相干扰\n2. 新命令执行会覆盖旧命令的取消标志\n3. 无法精确控制单个命令的取消\n4. 前端传递tool_call_id但后端未使用\n\n解决方案：\n1. 修改AppState数据结构，使用CommandID作为key\n2. 在exec_command中使用tool_call_id生成唯一命令ID\n3. 修改cancel_command_execution接收command_id参数\n4. 实现命令完成后的自动清理机制"
      }
    },
    {
      "id": "trace-3",
      "title": "错误处理和状态泄漏问题",
